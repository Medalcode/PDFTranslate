# Translation settings
SOURCE_LANG=en
TARGET_LANG=es

# Storage directories
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# ── LLM Translation (optional — vastly improves quality) ──────────────────────
# Provider options: gemini | openai | custom
# Leave LLM_API_KEY empty to fall back to Google Translate (free, no key needed)

LLM_PROVIDER=gemini
LLM_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.0-flash

# OpenAI example:
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# OpenAI-compatible (Together AI, Ollama, etc.):
# LLM_PROVIDER=custom
# LLM_API_KEY=your-key
# LLM_MODEL=meta-llama/Llama-3-8b-chat-hf
# LLM_BASE_URL=https://api.together.xyz/v1
